# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=rerb
PG_PASSWORD=changeme
PG_DB=rerb_db

# ── PgAdmin (interface web PostgreSQL) ───────────────────────────────────────
PG_WEB_MAIL=admin@example.com
PG_WEB_PASSWORD=changeme

# ── API Île-de-France Mobilités ───────────────────────────────────────────────
# Clé à obtenir sur https://prim.iledefrance-mobilites.fr
API_KEY=your_idfm_api_key_here
API_URL=https://prim.iledefrance-mobilites.fr/marketplace/stop-monitoring

# ── API FastAPI interne ───────────────────────────────────────────────────────
# Clé libre, utilisée par Streamlit pour s'authentifier auprès de l'API
RERB_API_KEY=changeme

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Paris
